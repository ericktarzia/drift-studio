{
  "name": "drift-studio",
  "displayName": "drift-studio",
  "description": "Drift database explorer for VSCode",
  "version": "0.4.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ericktarzia/drift-studio.git"
  },
  "bugs": {
    "url": "https://github.com/ericktarzia/drift-studio/issues"
  },
  "homepage": "https://github.com/ericktarzia/drift-studio#readme",
  "author": "Erick Tarzia <ericktarzia@gmail.com>",
  "publisher": "ericktarzia",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:driftStudioExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "drift-studio.exportAll",
        "title": "Drift Studio: Export DB Structure (JSON)"
      },
      {
        "command": "drift-studio.openDbViewer",
        "title": "Drift Studio: Open DB Viewer"
      },
      {
        "command": "drift-studio.openDbViewerForTable",
        "title": "Drift Studio: Open DB Viewer (table)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "driftStudio",
          "title": "Drift Studio",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "driftStudio": [
        {
          "id": "driftStudioExplorer",
          "name": "Drift Studio"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "drift-studio.exportAll",
          "when": "view == driftStudioExplorer",
          "group": "navigation"
        },
        {
          "command": "drift-studio.openDbViewer",
          "when": "view == driftStudioExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "drift-studio.openDbViewerForTable",
          "when": "view == driftStudioExplorer && viewItem == driftTableNode",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "release": "standard-version",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "sqlite3": "^5.1.7",
    "ws": "^8.13.0"
  }
}
